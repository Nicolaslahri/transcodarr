# ─────────────────────────────────────────────────────────────────────────────
# Transcodarr — Environment Configuration
#
# Both Main and Worker nodes use the same PORT variable.
# Role is determined automatically by the setup wizard (saved to ~/.transcodarr/config.json).
# ─────────────────────────────────────────────────────────────────────────────

# Port this node listens on (Main defaults to 3001, Worker defaults to 3002)
PORT=3001

# ── Main Node ────────────────────────────────────────────────────────────────
# MAIN_HOST=0.0.0.0          # Bind address (default: all interfaces)
# DB_PATH=./transcodarr.db   # SQLite database path
# NODE_NAME=Transcodarr Main # Display name shown in the UI

# ── Worker Node ──────────────────────────────────────────────────────────────
# WORKER_NAME=MyWorker                    # Display name for this worker
# MAIN_URL=http://192.168.0.100:3001      # URL of the Main node

# ── Web UI ───────────────────────────────────────────────────────────────────
# Copy this to apps/web/.env.local
# NEXT_PUBLIC_MAIN_URL=http://192.168.0.100:3001
